{
  "name": "openehr-bridge",
  "private": true,
  "version": "0.1.0",
  "description": "OpenEHR Bridge — Autonomous Healthcare Workflow Engine",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm --prefix packages/shared run build && npm --prefix apps/api run build && npm --prefix apps/web run build",
    "lint": "npm --prefix apps/api run lint && npm --prefix apps/web run lint",
    "db:migrate": "npm --prefix apps/api run db:migrate",
    "db:seed": "npm --prefix apps/api run db:seed",
    "db:studio": "npm --prefix apps/api run db:studio",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
