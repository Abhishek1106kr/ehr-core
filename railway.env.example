# ==============================================================================
# OpenEHR Bridge — Railway Production Environment Variables Template
# Copy these variables into your Railway Service Environment Variables tab.
# ==============================================================================

# Node Environment
NODE_ENV=production

# Server Port (Bound dynamically by Railway runtime)
PORT=4000

# SQLite / PostgreSQL Database URL
# For SQLite on Railway persistent volume: file:/app/storage/openehr.db
# For Railway PostgreSQL plugin: postgresql://postgres:password@containers-us-west-1.railway.app:5432/railway
DATABASE_URL=file:/app/storage/openehr.db

# Redis URL for BullMQ background workflow queue
REDIS_URL=redis://localhost:6379

# JWT Authentication Secret (Minimum 16 characters)
JWT_SECRET=production_super_secret_jwt_key_open_ehr_2026

# JWT Expiration Duration
JWT_EXPIRES_IN=8h

# Cookie Security (set to true if served over HTTPS)
COOKIE_SECURE=true

# Frontend Web Origin URL (Used for CORS and Cookie Domain)
WEB_ORIGIN=https://${RAILWAY_PUBLIC_DOMAIN}

# Session Idle Timeout (Minutes)
SESSION_IDLE_TIMEOUT_MINUTES=30

# Optional: Google Gemini API Key for ambient scribe AI features
# GEMINI_API_KEY=your_gemini_api_key_here

# Next.js Public API Gateway URL (Configured on Web Service)
NEXT_PUBLIC_API_URL=https://api-${RAILWAY_PUBLIC_DOMAIN}
