NODE_ENV=development
PORT=4000

# Postgres connection string (see docker-compose.yml at repo root)
DATABASE_URL="postgresql://openehr:openehr@localhost:5432/openehr_bridge?schema=public"

# Redis, used by BullMQ for the automation/workflow job queue
REDIS_URL="redis://localhost:6379"

# Generate a strong random value for production, e.g. `openssl rand -hex 32`
JWT_SECRET="dev-only-secret-change-me-32chars-min"
JWT_EXPIRES_IN="8h"

# Set to "true" behind HTTPS in production so session cookies require TLS
COOKIE_SECURE=false

# Origin allowed to call this API with credentials
WEB_ORIGIN="http://localhost:3000"

# Idle session timeout, mirrored in the auth cookie's maxAge
SESSION_IDLE_TIMEOUT_MINUTES=30

# Optional: enables Gemini-powered OCR/voice features in later phases.
# Leave unset to run entirely on mocked responses.
GEMINI_API_KEY=
